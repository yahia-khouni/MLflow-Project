{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "description": "HTTP requests per second over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"fastapi\"}[1m])",
          "legendFormat": "{{method}} {{handler}} {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 15, "lineWidth": 2 },
          "unit": "reqps"
        }
      }
    },
    {
      "title": "Latency P95",
      "description": "95th percentile response time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_highr_seconds_bucket{job=\"fastapi\"}[5m]))",
          "legendFormat": "P95 Latency",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_highr_seconds_bucket{job=\"fastapi\"}[5m]))",
          "legendFormat": "P50 Latency",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          }
        }
      }
    },
    {
      "title": "Error Rate (%)",
      "description": "Percentage of 4xx + 5xx responses",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"fastapi\", status=~\"4xx|5xx\"}[5m])) / sum(rate(http_requests_total{job=\"fastapi\"}[5m])) * 100 or vector(0)",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          }
        }
      }
    },
    {
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(http_requests_total{job=\"fastapi\"})",
          "legendFormat": "Total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" }
        }
      }
    },
    {
      "title": "Model Predictions",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(churn_predictions_total{prediction=\"true\"})",
          "legendFormat": "Churn: Yes",
          "refId": "A"
        },
        {
          "expr": "sum(churn_predictions_total{prediction=\"false\"})",
          "legendFormat": "Churn: No",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Avg Response Time",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(http_request_duration_highr_seconds_sum{job=\"fastapi\"}[5m]) / rate(http_request_duration_highr_seconds_count{job=\"fastapi\"}[5m])",
          "legendFormat": "Avg Latency",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "max": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          }
        }
      }
    },
    {
      "title": "Churn Prediction Distribution",
      "description": "Percentage of positive vs negative predictions over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(churn_predictions_total{prediction=\"true\"}[5m])",
          "legendFormat": "Churn = Yes",
          "refId": "A"
        },
        {
          "expr": "rate(churn_predictions_total{prediction=\"false\"}[5m])",
          "legendFormat": "Churn = No",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 40, "lineWidth": 2, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "title": "Probability Score Distribution",
      "description": "Histogram of churn probability scores - shows model confidence spread",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "increase(churn_probability_score_bucket{job=\"fastapi\"}[5m])",
          "legendFormat": "le={{le}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 30, "lineWidth": 1 }
        }
      }
    },
    {
      "title": "Batch Size Distribution",
      "description": "How large the batch requests are over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(batch_size_bucket{job=\"fastapi\"}[5m]))",
          "legendFormat": "Median batch size",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(batch_size_bucket{job=\"fastapi\"}[5m]))",
          "legendFormat": "P95 batch size",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Confidence Level Distribution",
      "description": "Distribution of high/medium/low confidence predictions",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(model_confidence_bucket{level=\"high\", le=\"1.0\"}) or vector(0)",
          "legendFormat": "High",
          "refId": "A"
        },
        {
          "expr": "sum(model_confidence_bucket{level=\"medium\", le=\"1.0\"}) or vector(0)",
          "legendFormat": "Medium",
          "refId": "B"
        },
        {
          "expr": "sum(model_confidence_bucket{level=\"low\", le=\"1.0\"}) or vector(0)",
          "legendFormat": "Low",
          "refId": "C"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["mlflow", "churn", "api"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Churn Prediction API",
  "uid": "churn-api-dashboard"
}
