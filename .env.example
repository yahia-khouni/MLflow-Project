# ============================================================
# ML Production Pipeline — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# NEVER commit .env to Git!
# ============================================================

# --- PostgreSQL (MLflow backend store) ---
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow_secret_2024
POSTGRES_DB=mlflow_db
POSTGRES_PORT=5432

# --- MinIO (artifact storage, S3-compatible) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret_2024
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MLFLOW_BUCKET_NAME=mlflow

# --- MLflow Tracking Server ---
MLFLOW_PORT=5000
MLFLOW_BACKEND_STORE_URI=postgresql://mlflow:mlflow_secret_2024@postgres:5432/mlflow_db
MLFLOW_DEFAULT_ARTIFACT_ROOT=s3://mlflow/

# --- AWS-style credentials (for MLflow → MinIO connection) ---
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin_secret_2024
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# --- Spark ---
SPARK_MASTER_PORT=7077
SPARK_MASTER_WEBUI_PORT=8080
SPARK_WORKER_CORES=2
SPARK_WORKER_MEMORY=2g

# --- FastAPI ---
API_PORT=8000
API_HOST=0.0.0.0
MODEL_NAME=churn-predictor
MODEL_STAGE=Production
MLFLOW_TRACKING_URI=http://mlflow:5000

# --- Prometheus ---
PROMETHEUS_PORT=9090

# --- Grafana ---
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
